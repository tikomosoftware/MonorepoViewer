{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monorepo Viewer",
  "version": "0.1.0",
  "identifier": "local.monorepo-viewer",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Monorepo Viewer",
        "width": 1280,
        "height": 820,
        "center": true,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
